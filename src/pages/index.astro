---
// Jake in Chicago — Portfolio Site
import '../styles/global.css';
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Jake Hamilton — Frontend Developer</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>

<!-- CTA MAP BACKGROUND LAYER -->
<div id="mapLayer">
  <iframe src="https://ctamap.vercel.app?lat=41.8827&lng=-87.6317&zoom=8&embed=true" loading="eager" tabindex="-1" aria-hidden="true"></iframe>
</div>


<!-- MAIN LAYOUT — two-column Chiang style -->
<div class="layout">

  <!-- LEFT SIDEBAR — STICKY -->
  <header class="sidebar">
    <div>
      <div class="sidebar-header">
        <h1 class="name">Jake Hamilton</h1>
        <p class="title"><span class="title-icon">&lt;/&gt;</span>Frontend Developer</p>
        <p class="tagline">Chicago-based developer with 10+ years building front-end experiences, from ad agency campaigns to university platforms to live transit maps.</p>
      </div>

      <nav>
        <ul class="sidebar-nav">
          <li>
            <a href="#about" class="nav-link active">
              <svg class="nav-dot" width="30" height="30" viewBox="0 0 30 30" xmlns="http://www.w3.org/2000/svg">
                <circle cx="15" cy="15" r="15" fill="var(--blue)" />
                <text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="18">1</text>
              </svg>
              <span>About</span>
            </a>
          </li>
          <li>
            <a href="#experience" class="nav-link">
              <svg class="nav-dot" width="30" height="30" viewBox="0 0 30 30" xmlns="http://www.w3.org/2000/svg">
                <circle cx="15" cy="15" r="15" fill="var(--red)" />
                <text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="18">2</text>
              </svg>
              <span>Experience</span>
            </a>
          </li>
          <li>
            <a href="#projects" class="nav-link">
              <svg class="nav-dot" width="30" height="30" viewBox="0 0 30 30" xmlns="http://www.w3.org/2000/svg">
                <circle cx="15" cy="15" r="15" fill="var(--green)" />
                <text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="18">3</text>
              </svg>
              <span>Projects</span>
            </a>
          </li>
          <li>
            <a href="#contact" class="nav-link">
              <svg class="nav-dot" width="30" height="30" viewBox="0 0 30 30" xmlns="http://www.w3.org/2000/svg">
                <circle cx="15" cy="15" r="15" fill="var(--orange)" />
                <text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="18">4</text>
              </svg>
              <span>Contact</span>
            </a>
          </li>
        </ul>
      </nav>
    </div>

    <div class="sidebar-footer">
      <!-- GitHub -->
      <a href="#" class="social-link" aria-label="GitHub">
        <svg viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" /></svg>
      </a>
      <!-- LinkedIn -->
      <a href="https://www.linkedin.com/in/jakehamilton/" class="social-link" aria-label="LinkedIn">
        <svg viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" /></svg>
      </a>
      <!-- Email (obfuscated) -->
      <a href="#" class="social-link" aria-label="Email" data-u="hamiltonjacoba" data-d="gmail.com">
        <svg viewBox="0 0 24 24"><path d="M1.5 8.67v8.58a3 3 0 003 3h15a3 3 0 003-3V8.67l-8.928 5.493a3 3 0 01-3.144 0L1.5 8.67z" /><path d="M22.5 6.908V6.75a3 3 0 00-3-3h-15a3 3 0 00-3 3v.158l9.714 5.978a1.5 1.5 0 001.572 0L22.5 6.908z" /></svg>
      </a>
    </div>
  </header>

  <!-- RIGHT CONTENT — SCROLLABLE -->
  <main class="content">

    <!-- Empty space so the map is the focus for the first viewport -->
    <div class="content-spacer">
      <div class="live-badge" id="liveBadge">
        <svg class="live-arrow" viewBox="0 0 16 16" width="18" height="18" fill="#fff"><path d="M13 13L4.5 4.5H11V2.5H1.5V12H3.5V5.5L12 14L13 13Z" /></svg>
        <div class="live-badge-text">
          Live CTA Trains<br />
          The Loop, Chicago
        </div>
      </div>
    </div>

    <!-- ABOUT -->
    <section class="section" id="about">
      <div class="section-header">
        <h2 class="section-header-text">About</h2>
        <svg class="line-badge" width="46" height="46" viewBox="0 0 46 46" xmlns="http://www.w3.org/2000/svg">
          <circle cx="23" cy="23" r="23" fill="var(--blue)" />
          <text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="30" dx="-1.5">1</text>
        </svg>
      </div>
      <div class="about-text">
        <p>Specializing in front-end development and accessibility, I've had the privilege of working across various settings — from digital agencies to client-side roles. My experience spans development teams of all sizes, allowing me to wear many hats and gain a well-rounded perspective over more than a decade of shipping websites, web apps, and responsive emails.</p>
        <p>My core toolkit is HTML, CSS/SASS, and JavaScript — vanilla where possible, React when it makes sense — plus CMS platforms like WordPress, Drupal, Shopify, and Magento, along with Adobe Cloud, AEM, and Adobe Commerce. I also have deep experience with email development, building and testing campaigns across every client imaginable. I care about accessibility, performance, and writing clean code that other people can actually maintain.</p>
        <p>Outside of professional roles, I've been active in the development community — hosting Magento Meetups in the Twin Cities area, attending Drupal Camp, and sitting in on online lectures like HigherEdWeb's Accessibility Summit. When I'm not at the keyboard, I'm into maker projects, following the <a href="#">Cubs</a> season, and figuring out the best way to mount an LED matrix to a wall.</p>
      </div>
    </section>

    <!-- EXPERIENCE -->
    <section class="section" id="experience">
      <div class="section-header">
        <h2 class="section-header-text">Experience</h2>
        <svg class="line-badge" width="46" height="46" viewBox="0 0 46 46" xmlns="http://www.w3.org/2000/svg">
          <circle cx="23" cy="23" r="23" fill="var(--red)" />
          <text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="30">2</text>
        </svg>
      </div>
      <div class="exp-list">

        <div class="exp-card current">
          <div class="exp-top">
            <h3 class="exp-company">Evolve Systems</h3>
            <span class="exp-date">2024 – Present</span>
          </div>
          <div class="exp-role">Senior Web Developer</div>
          <p class="exp-desc">Launched 3 websites within the first three months in close collaboration with designers and digital marketers. Train clients on WordPress to manage their sites independently.</p>
        </div>

        <div class="exp-card">
          <div class="exp-top">
            <h3 class="exp-company">Macalester College</h3>
            <span class="exp-date">2020 – 2023</span>
          </div>
          <div class="exp-role">Web Developer, Communications & Marketing</div>
          <p class="exp-desc">Sole web developer on the marketing team. Built 20+ custom WordPress blocks in JavaScript, managed a WPMU installation, and improved landing page speeds by 40% for 1M+ annual visitors.</p>
        </div>

        <div class="exp-card">
          <div class="exp-top">
            <h3 class="exp-company">Irish Titan</h3>
            <span class="exp-date">2017 – 2019</span>
          </div>
          <div class="exp-role">Front-end Developer</div>
          <p class="exp-desc">Spearheaded front-end development of a new Coolibar storefront, leading to a 34% sales increase. Built sales-optimized landing pages on WordPress, Shopify, and Magento. Hosted Magento Meetups in the Twin Cities area.</p>
        </div>

        <div class="exp-card">
          <div class="exp-top">
            <h3 class="exp-company">Betty</h3>
            <span class="exp-date">2014 – 2016</span>
          </div>
          <div class="exp-role">Digital Developer</div>
          <p class="exp-desc">Developed websites for major brands at a leading ad agency, including responsive email campaigns. Led Glukos Energy's web launch, contributing to $200K in sales. Crafted animations for Brach's, Buffalo Wild Wings, and the Minnesota Twins.</p>
        </div>

      </div>
      <a href="#" class="resume-link">View Full Résumé <svg class="arrow" viewBox="0 0 16 16" width="20" height="20" fill="currentColor"><path d="M3 13L11.5 4.5H5V2.5H14.5V12H12.5V5.5L4 14L3 13Z" /></svg></a>
    </section>

    <!-- PROJECTS -->
    <section class="section" id="projects">
      <div class="section-header">
        <h2 class="section-header-text">Projects &<br />Experiments</h2>
        <svg class="line-badge" width="46" height="46" viewBox="0 0 46 46" xmlns="http://www.w3.org/2000/svg">
          <circle cx="23" cy="23" r="23" fill="var(--green)" />
          <text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="30">3</text>
        </svg>
      </div>
      <div class="project-list">

        <div class="project-card">
          <div class="project-thumb">
            <div class="project-thumb-placeholder">img</div>
          </div>
          <a class="project-top" href="#">
            <h3 class="project-title">CTA Live Train Map</h3>
            <svg class="arrow" viewBox="0 0 16 16" width="20" height="20" fill="currentColor"><path d="M3 13L11.5 4.5H5V2.5H14.5V12H12.5V5.5L4 14L3 13Z" /></svg>
          </a>
          <p class="project-desc">Full-page real-time map of every active CTA train in Chicago. Animated train markers ride actual track geometry, with live positions from the CTA Train Tracker API.</p>
          <div class="tags">
            <span class="route-tag-wrap" style="--tag-color:var(--blue);"><svg class="route-tag" width="32" height="32" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><title>D3.js</title><circle cx="16" cy="16" r="16" fill="var(--blue)" /><text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="17">D3</text></svg><span class="route-tag-label">D3.js</span></span>
            <span class="route-tag-wrap" style="--tag-color:var(--orange);"><svg class="route-tag" width="32" height="32" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><title>GeoJSON</title><circle cx="16" cy="16" r="16" fill="var(--orange)" /><text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="17">GJ</text></svg><span class="route-tag-label">GeoJSON</span></span>
            <span class="route-tag-wrap" style="--tag-color:var(--red);"><svg class="route-tag" width="32" height="32" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><title>Vanilla JS</title><circle cx="16" cy="16" r="16" fill="var(--red)" /><text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="17">VJ</text></svg><span class="route-tag-label">Vanilla JS</span></span>
            <span class="route-tag-wrap" style="--tag-color:var(--green);"><svg class="route-tag" width="32" height="32" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><title>Node.js</title><circle cx="16" cy="16" r="16" fill="var(--green)" /><text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="17">No</text></svg><span class="route-tag-label">Node.js</span></span>
            <span class="route-tag-wrap" style="--tag-color:var(--blue);"><svg class="route-tag" width="32" height="32" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><title>CTA API</title><circle cx="16" cy="16" r="16" fill="var(--blue)" /><text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="17">CT</text></svg><span class="route-tag-label">CTA API</span></span>
          </div>
        </div>

        <div class="project-card">
          <div class="project-thumb">
            <div class="project-thumb-placeholder">img</div>
          </div>
          <div class="project-top">
            <h3 class="project-title">Internationalizing a National Chicken Chain</h3>
          </div>
          <p class="project-desc">Led the front-end internationalization effort for a major quick-service restaurant brand, integrating four different applications to create a seamless ecommerce experience for users on both ends of the process.</p>
          <div class="tags">
            <span class="route-tag-wrap" style="--tag-color:var(--red);"><svg class="route-tag" width="32" height="32" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><title>JavaScript</title><circle cx="16" cy="16" r="16" fill="var(--red)" /><text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="17">JS</text></svg><span class="route-tag-label">JavaScript</span></span>
            <span class="route-tag-wrap" style="--tag-color:var(--purple);"><svg class="route-tag" width="32" height="32" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><title>HTML/CSS</title><circle cx="16" cy="16" r="16" fill="var(--purple)" /><text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="17">HC</text></svg><span class="route-tag-label">HTML/CSS</span></span>
            <span class="route-tag-wrap" style="--tag-color:var(--orange);"><svg class="route-tag" width="32" height="32" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><title>API</title><circle cx="16" cy="16" r="16" fill="var(--orange)" /><text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="17">AP</text></svg><span class="route-tag-label">API</span></span>
          </div>
        </div>

        <div class="project-card">
          <div class="project-thumb">
            <div class="project-thumb-placeholder">img</div>
          </div>
          <div class="project-top">
            <h3 class="project-title">Rebuilding a Healthcare Company's Online Presence</h3>
          </div>
          <p class="project-desc">Rebuilt the web presence for a healthcare company from the ground up, championing UX through the dev role and working side by side with the design team from client meetings through launch.</p>
          <div class="tags">
            <span class="route-tag-wrap" style="--tag-color:var(--purple);"><svg class="route-tag" width="32" height="32" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><title>HTML/CSS</title><circle cx="16" cy="16" r="16" fill="var(--purple)" /><text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="17">HC</text></svg><span class="route-tag-label">HTML/CSS</span></span>
            <span class="route-tag-wrap" style="--tag-color:var(--red);"><svg class="route-tag" width="32" height="32" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><title>JavaScript</title><circle cx="16" cy="16" r="16" fill="var(--red)" /><text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="17">JS</text></svg><span class="route-tag-label">JavaScript</span></span>
          </div>
        </div>

        <div class="project-card">
          <div class="project-thumb">
            <div class="project-thumb-placeholder">img</div>
          </div>
          <div class="project-top">
            <h3 class="project-title">Creating a Storefront for UV-Protective Clothing</h3>
          </div>
          <p class="project-desc">Spearheaded front-end development of a new ecommerce storefront for a UV-protective clothing brand, leading to a significant sales increase on launch.</p>
          <div class="tags">
            <span class="route-tag-wrap" style="--tag-color:var(--orange);"><svg class="route-tag" width="32" height="32" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><title>Magento</title><circle cx="16" cy="16" r="16" fill="var(--orange)" /><text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="17">Mg</text></svg><span class="route-tag-label">Magento</span></span>
            <span class="route-tag-wrap" style="--tag-color:var(--red);"><svg class="route-tag" width="32" height="32" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><title>JavaScript</title><circle cx="16" cy="16" r="16" fill="var(--red)" /><text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="17">JS</text></svg><span class="route-tag-label">JavaScript</span></span>
            <span class="route-tag-wrap" style="--tag-color:var(--purple);"><svg class="route-tag" width="32" height="32" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><title>HTML/CSS</title><circle cx="16" cy="16" r="16" fill="var(--purple)" /><text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="17">HC</text></svg><span class="route-tag-label">HTML/CSS</span></span>
          </div>
        </div>

        <div class="project-card">
          <div class="project-thumb">
            <div class="project-thumb-placeholder">img</div>
          </div>
          <div class="project-top">
            <h3 class="project-title">Maintaining Web Properties for Higher Education</h3>
          </div>
          <p class="project-desc">Sole web developer on the marketing team, building 20+ custom WordPress blocks in JavaScript, managing a multisite installation, and improving landing page speeds for over a million annual visitors.</p>
          <div class="tags">
            <span class="route-tag-wrap" style="--tag-color:var(--green);"><svg class="route-tag" width="32" height="32" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><title>WordPress</title><circle cx="16" cy="16" r="16" fill="var(--green)" /><text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="17">WP</text></svg><span class="route-tag-label">WordPress</span></span>
            <span class="route-tag-wrap" style="--tag-color:var(--red);"><svg class="route-tag" width="32" height="32" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><title>JavaScript</title><circle cx="16" cy="16" r="16" fill="var(--red)" /><text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="17">JS</text></svg><span class="route-tag-label">JavaScript</span></span>
            <span class="route-tag-wrap" style="--tag-color:var(--purple);"><svg class="route-tag" width="32" height="32" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><title>HTML/CSS</title><circle cx="16" cy="16" r="16" fill="var(--purple)" /><text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="17">HC</text></svg><span class="route-tag-label">HTML/CSS</span></span>
