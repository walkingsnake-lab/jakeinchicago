---
// Jake in Chicago — Portfolio Site
import '../styles/global.css';
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Jake in Chicago — Frontend Developer</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>

<!-- CTA MAP BACKGROUND LAYER -->
<div id="mapLayer">
  <iframe src="https://gojackrabbitgo.pythonanywhere.com?lat=41.8827&lng=-87.6317&zoom=8&embed=true" loading="eager" tabindex="-1" aria-hidden="true"></iframe>
</div>


<!-- MAIN LAYOUT — two-column Chiang style -->
<div class="layout">

  <!-- LEFT SIDEBAR — STICKY -->
  <header class="sidebar">
    <div>
      <div class="sidebar-header">
        <h1 class="name">Jake in Chicago</h1>
        <p class="title"><span class="title-icon">&lt;/&gt;</span>Frontend Developer</p>
        <p class="tagline">I build data-driven interfaces and real-time visualizations for the web.</p>
      </div>

      <nav>
        <ul class="sidebar-nav">
          <li>
            <a href="#about" class="nav-link active">
              <svg class="nav-dot" width="30" height="30" viewBox="0 0 30 30" xmlns="http://www.w3.org/2000/svg">
                <circle cx="15" cy="15" r="15" fill="var(--blue)" />
                <text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="18">1</text>
              </svg>
              <span>About</span>
            </a>
          </li>
          <li>
            <a href="#experience" class="nav-link">
              <svg class="nav-dot" width="30" height="30" viewBox="0 0 30 30" xmlns="http://www.w3.org/2000/svg">
                <circle cx="15" cy="15" r="15" fill="var(--red)" />
                <text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="18">2</text>
              </svg>
              <span>Experience</span>
            </a>
          </li>
          <li>
            <a href="#projects" class="nav-link">
              <svg class="nav-dot" width="30" height="30" viewBox="0 0 30 30" xmlns="http://www.w3.org/2000/svg">
                <circle cx="15" cy="15" r="15" fill="var(--green)" />
                <text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="18">3</text>
              </svg>
              <span>Projects</span>
            </a>
          </li>
          <li>
            <a href="#contact" class="nav-link">
              <svg class="nav-dot" width="30" height="30" viewBox="0 0 30 30" xmlns="http://www.w3.org/2000/svg">
                <circle cx="15" cy="15" r="15" fill="var(--orange)" />
                <text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="18">4</text>
              </svg>
              <span>Contact</span>
            </a>
          </li>
        </ul>
      </nav>
    </div>

    <div class="sidebar-footer">
      <!-- GitHub -->
      <a href="#" class="social-link" aria-label="GitHub">
        <svg viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" /></svg>
      </a>
      <!-- LinkedIn -->
      <a href="#" class="social-link" aria-label="LinkedIn">
        <svg viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" /></svg>
      </a>
      <!-- Email -->
      <a href="#" class="social-link" aria-label="Email">
        <svg viewBox="0 0 24 24"><path d="M1.5 8.67v8.58a3 3 0 003 3h15a3 3 0 003-3V8.67l-8.928 5.493a3 3 0 01-3.144 0L1.5 8.67z" /><path d="M22.5 6.908V6.75a3 3 0 00-3-3h-15a3 3 0 00-3 3v.158l9.714 5.978a1.5 1.5 0 001.572 0L22.5 6.908z" /></svg>
      </a>
    </div>
  </header>

  <!-- RIGHT CONTENT — SCROLLABLE -->
  <main class="content">

    <!-- Empty space so the map is the focus for the first viewport -->
    <div class="content-spacer">
      <div class="live-badge" id="liveBadge">
        <svg class="live-arrow" viewBox="0 0 16 16" width="18" height="18" fill="#fff"><path d="M13 13L4.5 4.5H11V2.5H1.5V12H3.5V5.5L12 14L13 13Z" /></svg>
        <div class="live-badge-text">
          Live CTA Trains<br />
          The Loop, Chicago
        </div>
      </div>
    </div>

    <!-- ABOUT -->
    <section class="section" id="about">
      <div class="section-header">
        <span class="section-header-text">About</span>
        <svg class="line-badge" width="46" height="46" viewBox="0 0 46 46" xmlns="http://www.w3.org/2000/svg">
          <circle cx="23" cy="23" r="23" fill="var(--blue)" />
          <text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="30" dx="-1.5">1</text>
        </svg>
      </div>
      <div class="about-text">
        <p>I'm a frontend developer who gravitates toward the intersection of data, real-time systems, and visual design. I enjoy building things that make complex information feel immediate and tangible — whether that's live transit data rendered on a map or baseball stats surfaced through a chat bot.</p>
        <p>My sweet spot is working with APIs, vanilla JavaScript, and D3.js to craft interfaces that feel alive. I'm drawn to projects where the data itself becomes the design — where structure and motion emerge directly from what's happening in the real world.</p>
        <p>Outside of code, I'm into maker projects, following the <a href="#">Cubs</a> season, and figuring out the best way to mount an LED matrix to a wall.</p>
      </div>
    </section>

    <!-- EXPERIENCE -->
    <section class="section" id="experience">
      <div class="section-header">
        <span class="section-header-text">Experience</span>
        <svg class="line-badge" width="46" height="46" viewBox="0 0 46 46" xmlns="http://www.w3.org/2000/svg">
          <circle cx="23" cy="23" r="23" fill="var(--red)" />
          <text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="30">2</text>
        </svg>
      </div>
      <div class="exp-list">

        <div class="exp-card current">
          <div class="exp-top">
            <h3 class="exp-company">Company Name</h3>
            <span class="exp-date">2023 – Present</span>
          </div>
          <div class="exp-role">Frontend Developer</div>
          <p class="exp-desc">Build and maintain customer-facing web applications with a focus on data visualization and real-time features. Collaborate with design and backend teams to ship performant, accessible interfaces.</p>
        </div>

        <div class="exp-card">
          <div class="exp-top">
            <h3 class="exp-company">Previous Co</h3>
            <span class="exp-date">2021 – 2023</span>
          </div>
          <div class="exp-role">Frontend Engineer</div>
          <p class="exp-desc">Developed interactive dashboards and internal tools. Led migration of legacy jQuery codebase to modern vanilla JS architecture. Implemented CI/CD pipelines and automated testing.</p>
        </div>

        <div class="exp-card">
          <div class="exp-top">
            <h3 class="exp-company">Starter Corp</h3>
            <span class="exp-date">2019 – 2021</span>
          </div>
          <div class="exp-role">Junior Developer</div>
          <p class="exp-desc">Contributed to frontend features across multiple client projects. Built responsive layouts, integrated third-party APIs, and maintained design system components.</p>
        </div>

      </div>
      <a href="#" class="resume-link">View Full Résumé <svg class="arrow" viewBox="0 0 16 16" width="20" height="20" fill="currentColor"><path d="M3 13L11.5 4.5H5V2.5H14.5V12H12.5V5.5L4 14L3 13Z" /></svg></a>
    </section>

    <!-- PROJECTS -->
    <section class="section" id="projects">
      <div class="section-header">
        <span class="section-header-text">Projects &<br />Experiments</span>
        <svg class="line-badge" width="46" height="46" viewBox="0 0 46 46" xmlns="http://www.w3.org/2000/svg">
          <circle cx="23" cy="23" r="23" fill="var(--green)" />
          <text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="30">3</text>
        </svg>
      </div>
      <div class="project-list">

        <div class="project-card">
          <div class="project-thumb">
            <div class="project-thumb-placeholder">img</div>
          </div>
          <a class="project-top" href="#">
            <h3 class="project-title">CTA Live Train Map</h3>
            <svg class="arrow" viewBox="0 0 16 16" width="20" height="20" fill="currentColor"><path d="M3 13L11.5 4.5H5V2.5H14.5V12H12.5V5.5L4 14L3 13Z" /></svg>
          </a>
          <p class="project-desc">Full-page real-time map of every active CTA train in Chicago. Animated train markers ride actual track geometry, with live positions from the CTA Train Tracker API.</p>
          <div class="tags">
            <span class="route-tag-wrap" style="--tag-color:var(--blue);"><svg class="route-tag" width="32" height="32" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><title>D3.js</title><circle cx="16" cy="16" r="16" fill="var(--blue)" /><text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="17">D3</text></svg><span class="route-tag-label">D3.js</span></span>
            <span class="route-tag-wrap" style="--tag-color:var(--orange);"><svg class="route-tag" width="32" height="32" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><title>GeoJSON</title><circle cx="16" cy="16" r="16" fill="var(--orange)" /><text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="17">GJ</text></svg><span class="route-tag-label">GeoJSON</span></span>
            <span class="route-tag-wrap" style="--tag-color:var(--red);"><svg class="route-tag" width="32" height="32" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><title>Vanilla JS</title><circle cx="16" cy="16" r="16" fill="var(--red)" /><text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="17">VJ</text></svg><span class="route-tag-label">Vanilla JS</span></span>
            <span class="route-tag-wrap" style="--tag-color:var(--green);"><svg class="route-tag" width="32" height="32" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><title>Node.js</title><circle cx="16" cy="16" r="16" fill="var(--green)" /><text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="17">No</text></svg><span class="route-tag-label">Node.js</span></span>
            <span class="route-tag-wrap" style="--tag-color:var(--blue);"><svg class="route-tag" width="32" height="32" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><title>CTA API</title><circle cx="16" cy="16" r="16" fill="var(--blue)" /><text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="17">CT</text></svg><span class="route-tag-label">CTA API</span></span>
          </div>
        </div>

        <div class="project-card">
          <div class="project-thumb">
            <div class="project-thumb-placeholder">img</div>
          </div>
          <a class="project-top" href="#">
            <h3 class="project-title">CTA LED Departure Board</h3>
            <svg class="arrow" viewBox="0 0 16 16" width="20" height="20" fill="currentColor"><path d="M3 13L11.5 4.5H5V2.5H14.5V12H12.5V5.5L4 14L3 13Z" /></svg>
          </a>
          <p class="project-desc">Physical departure display showing real-time CTA arrivals on an HUB75 RGB LED matrix, driven by a Raspberry Pi Zero 2 W. Renders arrivals in the style of station signage.</p>
          <div class="tags">
            <span class="route-tag-wrap" style="--tag-color:var(--green);"><svg class="route-tag" width="32" height="32" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><title>Raspberry Pi</title><circle cx="16" cy="16" r="16" fill="var(--green)" /><text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="17">Pi</text></svg><span class="route-tag-label">Raspberry Pi</span></span>
            <span class="route-tag-wrap" style="--tag-color:var(--purple);"><svg class="route-tag" width="32" height="32" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><title>Python</title><circle cx="16" cy="16" r="16" fill="var(--purple)" /><text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="17">Py</text></svg><span class="route-tag-label">Python</span></span>
            <span class="route-tag-wrap" style="--tag-color:var(--orange);"><svg class="route-tag" width="32" height="32" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><title>HUB75</title><circle cx="16" cy="16" r="16" fill="var(--orange)" /><text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="17">75</text></svg><span class="route-tag-label">HUB75</span></span>
            <span class="route-tag-wrap" style="--tag-color:var(--blue);"><svg class="route-tag" width="32" height="32" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><title>CTA API</title><circle cx="16" cy="16" r="16" fill="var(--blue)" /><text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="17">CT</text></svg><span class="route-tag-label">CTA API</span></span>
          </div>
        </div>

        <div class="project-card">
          <div class="project-thumb">
            <div class="project-thumb-placeholder">img</div>
          </div>
          <a class="project-top" href="#">
            <h3 class="project-title">MLB Telegram Bot</h3>
            <svg class="arrow" viewBox="0 0 16 16" width="20" height="20" fill="currentColor"><path d="M3 13L11.5 4.5H5V2.5H14.5V12H12.5V5.5L4 14L3 13Z" /></svg>
          </a>
          <p class="project-desc">Telegram bot that serves MLB player data, career timelines, and stats on demand. Handles edge cases like franchise relocations, Negro League teams, and in-memory caching.</p>
          <div class="tags">
            <span class="route-tag-wrap" style="--tag-color:var(--purple);"><svg class="route-tag" width="32" height="32" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><title>Python</title><circle cx="16" cy="16" r="16" fill="var(--purple)" /><text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="17">Py</text></svg><span class="route-tag-label">Python</span></span>
            <span class="route-tag-wrap" style="--tag-color:var(--blue);"><svg class="route-tag" width="32" height="32" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><title>Telegram API</title><circle cx="16" cy="16" r="16" fill="var(--blue)" /><text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="17">TG</text></svg><span class="route-tag-label">Telegram API</span></span>
            <span class="route-tag-wrap" style="--tag-color:var(--red);"><svg class="route-tag" width="32" height="32" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><title>MLB Stats API</title><circle cx="16" cy="16" r="16" fill="var(--red)" /><text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="17">ML</text></svg><span class="route-tag-label">MLB Stats API</span></span>
          </div>
        </div>

      </div>
    </section>

    <!-- CONTACT -->
    <section class="section" id="contact">
      <div class="section-header">
        <span class="section-header-text">Contact</span>
        <svg class="line-badge" width="46" height="46" viewBox="0 0 46 46" xmlns="http://www.w3.org/2000/svg">
          <circle cx="23" cy="23" r="23" fill="var(--orange)" />
          <text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="30">4</text>
        </svg>
      </div>
      <p class="contact-text">I'm always open to hearing about interesting projects, collaboration opportunities, or just chatting about transit data and baseball stats.</p>
      <a href="mailto:jake@example.com" class="contact-email">jake@example.com</a>
    </section>

  </main>
</div>

<!-- FOOTER -->
<footer class="footer">
  <p class="footer-text">
    Loosely inspired by <a href="https://brittanychiang.com/" target="_blank">Brittany Chiang</a>.
    Built with vanilla HTML, CSS & JS. The background is a live CTA train map.
    All text set in Helvetica Neue.
  </p>
</footer>

<script>
  // =============================================
  // PARALLAX + FADE MAP ON SCROLL
  // =============================================
  const mapLayer = document.getElementById('mapLayer');

  window.addEventListener('scroll', () => {
    const scrollY = window.scrollY;
    const vh = window.innerHeight;

    const fadeProgress = Math.min(scrollY / (vh * 0.7), 1);

    mapLayer.style.transform = `translateY(${-scrollY * 0.2}px)`;

    const opacity = Math.max(0, 1 - fadeProgress);
    mapLayer.style.opacity = opacity;
  }, { passive: true });

  mapLayer.style.opacity = '1';


  // =============================================
  // SECTION REVEAL ON SCROLL
  // =============================================
  const sections = document.querySelectorAll('.section');

  function revealSections() {
    const trigger = window.innerHeight * 0.88;
    sections.forEach(s => {
      if (s.getBoundingClientRect().top < trigger) {
        s.classList.add('revealed');
      }
    });
  }

  window.addEventListener('scroll', revealSections, { passive: true });
  window.addEventListener('load', revealSections);
  revealSections();


  // =============================================
  // ACTIVE NAV TRACKING
  // =============================================
  const navLinks = document.querySelectorAll('.nav-link');
  const sectionEls = document.querySelectorAll('.section[id]');

  function updateActiveNav() {
    let current = '';
    sectionEls.forEach(s => {
      if (s.getBoundingClientRect().top < window.innerHeight * 0.4) {
        current = s.id;
      }
    });
    navLinks.forEach(l => {
      l.classList.toggle('active', l.getAttribute('href') === '#' + current);
    });
  }

  window.addEventListener('scroll', updateActiveNav, { passive: true });


  // =============================================
  // POSITION MAP CENTER OVER RIGHT COLUMN
  // =============================================
  const contentEl = document.querySelector('.content');
  const mapLayerEl = document.getElementById('mapLayer');

  function positionMap() {
    const isMobile = window.innerWidth <= 900;
    if (isMobile) {
      mapLayerEl.style.setProperty('--iframe-offset', '0px');
      mapLayerEl.style.setProperty('--vignette-x', '50%');
      return;
    }
    const rect = contentEl.getBoundingClientRect();
    const colCenter = rect.left + rect.width / 2;
    const vpCenter = window.innerWidth / 2;
    const offset = colCenter - vpCenter;
    mapLayerEl.style.setProperty('--iframe-offset', offset + 'px');
    const vignettePercent = (colCenter / window.innerWidth) * 100;
    mapLayerEl.style.setProperty('--vignette-x', vignettePercent + '%');
  }

  window.addEventListener('resize', positionMap);
  positionMap();

  // =============================================
  // FADE LIVE BADGE ON SCROLL
  // =============================================
  const liveBadge = document.getElementById('liveBadge');
  window.addEventListener('scroll', () => {
    const progress = Math.min(window.scrollY / (window.innerHeight * 0.3), 1);
    liveBadge.style.opacity = 1 - progress;
  }, { passive: true });
</script>
</body>
</html>
