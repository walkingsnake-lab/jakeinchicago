      </div>
    </section>

    <!-- CONTACT -->
    <section class="section" id="contact">
      <div class="section-header">
        <h2 class="section-header-text">Contact</h2>
        <svg class="line-badge" width="46" height="46" viewBox="0 0 46 46" xmlns="http://www.w3.org/2000/svg">
          <circle cx="23" cy="23" r="23" fill="var(--orange)" />
          <text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" fill="#fff" font-family="Inter, Helvetica, Arial, sans-serif" font-weight="700" font-size="30">4</text>
        </svg>
      </div>
      <p class="contact-text">I'm always open to hearing about interesting projects, collaboration opportunities, or just chatting about transit data and baseball stats.</p>
      <a href="#" class="contact-email" data-u="hamiltonjacoba" data-d="gmail.com">[click to reveal email]</a>
    </section>

  </main>
</div>

<!-- FOOTER -->
<footer class="footer">
  <div class="footer-bar">
    <p class="footer-credit"><a href="https://ctamap.vercel.app" target="_blank">CTA trains map</a> built by me, powered by the <a href="https://www.transitchicago.com/developers/" target="_blank">CTA Train Tracker API</a> and rendered with <a href="https://d3js.org/" target="_blank">D3.js</a>. Site built with <a href="https://astro.build/" target="_blank">Astro</a> and deployed on <a href="https://vercel.com/" target="_blank">Vercel</a>.</p>
    <div class="footer-social">
      <!-- GitHub -->
