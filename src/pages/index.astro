<script>
  // =============================================
  // PARALLAX + FADE MAP ON SCROLL
  // =============================================
  const mapLayer = document.getElementById('mapLayer');

  window.addEventListener('scroll', () => {
    const scrollY = window.scrollY;
    const vh = window.innerHeight;

    const fadeProgress = Math.min(scrollY / (vh * 0.7), 1);

    mapLayer.style.transform = `translateY(${-scrollY * 0.2}px)`;

    const opacity = Math.max(0, 1 - fadeProgress);
    mapLayer.style.opacity = opacity;
  }, { passive: true });

  mapLayer.style.opacity = '1';


  // =============================================
  // SECTION REVEAL ON SCROLL
  // =============================================
  const sections = document.querySelectorAll('.section');

  function revealSections() {
    const trigger = window.innerHeight * 0.88;
    sections.forEach(s => {
      if (s.getBoundingClientRect().top < trigger) {
        s.classList.add('revealed');
      }
    });
  }

  window.addEventListener('scroll', revealSections, { passive: true });
  window.addEventListener('load', revealSections);
  revealSections();


  // =============================================
  // ACTIVE NAV TRACKING
  // =============================================
  const navLinks = document.querySelectorAll('.nav-link');
  const sectionEls = document.querySelectorAll('.section[id]');

  function updateActiveNav() {
    let current = '';
    sectionEls.forEach(s => {
      if (s.getBoundingClientRect().top < window.innerHeight * 0.4) {
        current = s.id;
      }
    });
    navLinks.forEach(l => {
      l.classList.toggle('active', l.getAttribute('href') === '#' + current);
    });
  }

  window.addEventListener('scroll', updateActiveNav, { passive: true });


  // =============================================
  // POSITION MAP CENTER OVER RIGHT COLUMN
  // =============================================
  const contentEl = document.querySelector('.content');
  const mapLayerEl = document.getElementById('mapLayer');

  function positionMap() {
    const isMobile = window.innerWidth <= 900;
    if (isMobile) {
      mapLayerEl.style.setProperty('--iframe-offset', '0px');
      mapLayerEl.style.setProperty('--vignette-x', '50%');
      return;
    }
    const rect = contentEl.getBoundingClientRect();
    const colCenter = rect.left + rect.width / 2;
    const vpCenter = window.innerWidth / 2;
    const offset = colCenter - vpCenter;
    mapLayerEl.style.setProperty('--iframe-offset', offset + 'px');
    const vignettePercent = (colCenter / window.innerWidth) * 100;
    mapLayerEl.style.setProperty('--vignette-x', vignettePercent + '%');
  }

  window.addEventListener('resize', positionMap);
  positionMap();

  // =============================================
  // FADE LIVE BADGE ON SCROLL
  // =============================================
  const liveBadge = document.getElementById('liveBadge');
  window.addEventListener('scroll', () => {
    const progress = Math.min(window.scrollY / (window.innerHeight * 0.3), 1);
    liveBadge.style.opacity = 1 - progress;
  }, { passive: true });


  // =============================================
  // FADE SIDEBAR SOCIAL WHEN FOOTER VISIBLE
  // =============================================
  const sidebarFooter = document.querySelector('.sidebar-footer');
  const footerEl = document.querySelector('.footer');

  if (sidebarFooter && footerEl) {
    window.addEventListener('scroll', () => {
      const footerRect = footerEl.getBoundingClientRect();
      const vh = window.innerHeight;
      // Fade: starts when footer is 2x viewport away, fully hidden when footer enters viewport
      if (footerRect.top >= vh * 2) {
        sidebarFooter.style.opacity = '1';
      } else if (footerRect.top <= vh) {
        sidebarFooter.style.opacity = '0';
      } else {
        sidebarFooter.style.opacity = String((footerRect.top - vh) / vh);
      }
    }, { passive: true });
  }


  // =============================================
  // EMAIL OBFUSCATION
  // =============================================
  document.querySelectorAll('[data-u]').forEach(el => {
    const addr = el.dataset.u + '@' + el.dataset.d;
    el.href = 'mailto:' + addr;
    if (el.classList.contains('contact-email')) {
      el.textContent = addr;
    }
  });
</script>
</body>
